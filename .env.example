# Copy this to `.env` and fill in real values.
# `.env` is gitignored; never commit a real one.

# Django
DEBUG=True
SECRET_KEY=replace-me-with-a-real-secret
# TIME_ZONE=Europe/Paris   # uncomment + set to your tz, e.g. Africa/Algiers, America/New_York
# Comma-separated allowed hosts. Default '*' (dev). Set real hosts in prod.
# ALLOWED_HOSTS=sast.example.com,www.sast.example.com
# Show the Django templated UI under /debug/. Default True (dev).
# Set False in production so only the Vue SPA at /app/ is exposed.
# SAST_DEBUG_UI=True
# Production (nginx) origins for Django's CSRF Origin check —
# scheme included, comma-separated.
# CSRF_TRUSTED_ORIGINS=http://localhost,http://192.168.1.20
# Set True ONLY when nginx terminates HTTPS (enables SSL redirect,
# secure cookies, HSTS). Plain-HTTP LAN demos keep this False.
# SAST_TLS=False

# PostgreSQL
DATABASE_NAME=sast_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Sprint 2 — source-ingest limits (defaults shown)
# SAST_MAX_UPLOAD_SIZE_MB=250
# SAST_MAX_EXTRACTED_SIZE_MB=750
# SAST_GIT_CLONE_TIMEOUT=60

# Tool paths (None = auto-detect via PATH)
# SEMGREP_PATH=

# Sprint 3 — SonarQube (optional)
# SONAR_HOST=http://localhost:9000
# SONAR_TOKEN=
# SONAR_PROJECT_KEY=
# SONAR_SCANNER_PATH=          # None = auto-detect via PATH
# Which Sonar issue types to import. Default = VULNERABILITY only
# (security). Modern Sonar moves security hotspots to a separate API.
# Set to empty string to import everything (incl. BUG, CODE_SMELL).
# SAST_SONAR_ISSUE_TYPES=VULNERABILITY
# Sonar task-queue polling (seconds): interval between checks + total cap.
# SAST_SONAR_POLL_INTERVAL=2
# SAST_SONAR_POLL_TIMEOUT=300
