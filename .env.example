# Copy this to `.env` and fill in real values.
# `.env` is gitignored; never commit a real one.

# Django
DEBUG=True
SECRET_KEY=replace-me-with-a-real-secret

# PostgreSQL
DATABASE_NAME=sast_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Sprint 2 — source-ingest limits (defaults shown)
# SAST_MAX_UPLOAD_SIZE_MB=250
# SAST_MAX_EXTRACTED_SIZE_MB=750
# SAST_GIT_CLONE_TIMEOUT=60

# Tool paths (None = auto-detect via PATH)
# SEMGREP_PATH=

# Sprint 3 — SonarQube (optional, in-progress)
# SONAR_HOST=http://localhost:9000
# SONAR_TOKEN=
# SONAR_PROJECT_KEY=
